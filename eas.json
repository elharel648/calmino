{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "ios": {
        "credentialsSource": "remote",
        "prebuildCommand": "bash .eas/build/prebuild-icons.sh && bash .eas/build/prebuild.sh",
        "appExtensions": [
          {
            "targetName": "CalmParentLiveActivity",
            "bundleIdentifier": "com.harel.calmparentapp.LiveActivity"
          }
        ]
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "zivtothani@gmail.com",
        "ascAppId": "6756817719"
      }
    }
  }
}