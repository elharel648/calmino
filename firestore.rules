rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===================
    // HELPER FUNCTIONS
    // ===================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the current user is the direct parent of the baby
    function isParentOfBaby(babyId) {
      let babyDoc = get(/databases/$(database)/documents/babies/$(babyId));
      return babyDoc != null && babyDoc.data.parentId == request.auth.uid;
    }

    // LEGACY + MULTI-CHILD: used from events, medications, teeth, etc. (NOT from babies rule - would be recursive).
    // Checks legacy babyId field AND multi-child (get baby doc to compare parentId with family admin).
    function hasFamilyAccessToBaby(babyId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let familyId = userDoc != null ? userDoc.data.familyId : null;
      let familyDoc = familyId != null ? get(/databases/$(database)/documents/families/$(familyId)) : null;
      let isMember = familyDoc != null && familyDoc.data.members[request.auth.uid] != null;
      let isLegacy = isMember && familyDoc.data.babyId == babyId;
      let babyDoc = get(/databases/$(database)/documents/babies/$(babyId));
      let isAdminChild = isMember && babyDoc != null && babyDoc.data.parentId == familyDoc.data.createdBy;
      return isLegacy || isAdminChild;
    }

    // MULTI-CHILD: check access by the baby's parentId (no recursive get needed).
    // Pass resource.data.parentId from the babies rule so we don't need to re-fetch.
    function hasFamilyAccessToBabyByParentId(babyParentId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let familyId = userDoc != null ? userDoc.data.familyId : null;
      let familyDoc = familyId != null ? get(/databases/$(database)/documents/families/$(familyId)) : null;
      let isMember = familyDoc != null && familyDoc.data.members[request.auth.uid] != null;
      return isMember && babyParentId == familyDoc.data.createdBy;
    }

    // Check guest access — guests have guestChildIds array in their user doc (1 get, no family read).
    // These fields are written EXCLUSIVELY by the joinFamilyByCode Cloud Function (Admin SDK);
    // owner writes may only shrink them (see users rule), so they are trustworthy here.
    // The 24h guest window is enforced via guestAccess[guestFamilyId].expiresAt — fail closed.
    function hasGuestAccessToBaby(babyId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null
        && userDoc.data.get('guestChildIds', []).hasAny([babyId])
        && userDoc.data.get('guestAccess', {}).get(userDoc.data.get('guestFamilyId', ''), {}).get('expiresAt', timestamp.date(1970, 1, 1)) > request.time;
    }

    // Owner writes to their own user doc may only SHRINK guest-access state
    // (sign-out / leave-guest cleanup). Granting or extending guest access happens
    // exclusively via the joinFamilyByCode Cloud Function — never from the client.
    function guestGrantNotEscalated() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['guestChildIds', 'guestAccess', 'guestFamilyId'])
        || (
          request.resource.data.get('guestChildIds', []).hasOnly(resource.data.get('guestChildIds', []))
          && request.resource.data.get('guestAccess', {}).diff(resource.data.get('guestAccess', {})).addedKeys().size() == 0
          && request.resource.data.get('guestAccess', {}).diff(resource.data.get('guestAccess', {})).changedKeys().size() == 0
          && (!request.resource.data.keys().hasAny(['guestFamilyId'])
              || request.resource.data.get('guestFamilyId', '') == resource.data.get('guestFamilyId', ''))
        );
    }

    // ===================
    // THROTTLE COLLECTION (server-only — used by Cloud Functions for rate limits)
    // ===================
    match /_throttle/{doc} {
      allow read, write: if false;
    }

    // ===================
    // USERS COLLECTION
    // ===================
    match /users/{userId} {
      // get: owner can always read their data
      // OR any authenticated user can read if user is an active sitter
      allow get: if isOwner(userId) ||
                     (isAuthenticated() && resource.data.get('isSitter', false) == true && resource.data.get('sitterActive', false) == true);

      // list: limit queries to max 100 to prevent enumeration scraping attacks
      allow list: if isOwner(userId) ||
                     (isAuthenticated() && resource.data.get('isSitter', false) == true && resource.data.get('sitterActive', false) == true && request.query.limit <= 100);

      // Create: owner only, and never with guest-access fields (those are granted
      // exclusively by the joinFamilyByCode Cloud Function via the Admin SDK)
      allow create: if isOwner(userId) &&
                       !request.resource.data.keys().hasAny(['guestChildIds', 'guestAccess', 'guestFamilyId']);

      // Update: owner may write anything EXCEPT granting/extending guest access
      allow update: if (isOwner(userId) && guestGrantNotEscalated()) ||
                       // OR any authenticated user may bump sitter stats — bounded to
                       // +1 increments and a sane rating range to prevent stat inflation
                       (isAuthenticated() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalProfileViews', 'sitterRating', 'sitterReviewCount', 'sitterBadges']) &&
                        request.resource.data.get('sitterRating', 0) >= 0 &&
                        request.resource.data.get('sitterRating', 0) <= 5 &&
                        request.resource.data.get('totalProfileViews', 0) <= resource.data.get('totalProfileViews', 0) + 1 &&
                        request.resource.data.get('sitterReviewCount', 0) <= resource.data.get('sitterReviewCount', 0) + 1);

      // Delete: only owner
      allow delete: if isOwner(userId);

      // Reminders subcollection
      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ===================
    // FAMILIES COLLECTION
    // ===================
    match /families/{familyId} {
      // get: members only (protect family data from non-members)
      allow get: if isAuthenticated() && (
        resource.data.members[request.auth.uid] != null ||
        resource.data.createdBy == request.auth.uid
      );
      // list: limited to 1 result — supports invite-code join query (where inviteCode == x, limit 1)
      // without allowing bulk enumeration of all families.
      allow list: if isAuthenticated() && request.query.limit <= 1;
      
      // Create: any authenticated
      allow create: if isAuthenticated();
      
      // Update: admins of the family, OR a user leaving (removing ONLY their own key).
      // Self-JOIN was removed: joins happen exclusively via the joinFamilyByCode
      // Cloud Function (Admin SDK), which assigns the role server-side — closing
      // the hole where a client could self-insert as 'admin'.
      allow update: if isAuthenticated() && (
        resource.data.members[request.auth.uid].role == 'admin' ||
        // Self-leave: only the caller's own key is removed; nothing added or changed
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.resource.data.members.diff(resource.data.members).removedKeys().hasOnly([request.auth.uid]) &&
         request.resource.data.members.diff(resource.data.members).addedKeys().size() == 0 &&
         request.resource.data.members.diff(resource.data.members).changedKeys().size() == 0)
      );
      
      // Delete: only creator (who should be an admin)
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      
      // Presence subcollection
      match /presence/{memberId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ===================
    // BABIES COLLECTION
    // ===================
    match /babies/{babyId} {
      // Read: parent OR family member (hasFamilyAccessToBabyByParentId covers both legacy + multi-child)
      // hasFamilyAccessToBaby is intentionally NOT used here to avoid recursive get(babies/...)
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        hasFamilyAccessToBabyByParentId(resource.data.parentId) ||
        hasGuestAccessToBaby(babyId)
      );
      
      // Create: authenticated with parentId matching
      allow create: if isAuthenticated() && request.resource.data.parentId == request.auth.uid;
      
      // Update: parent
      allow update: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid
      );
      
      // Delete: only parent
      allow delete: if isAuthenticated() && resource.data.parentId == request.auth.uid;

      // Medications subcollection
      match /medications/{medId} {
        // Read: parent OR family member OR guest with access
        allow read: if isAuthenticated() && (
          isParentOfBaby(babyId) ||
          hasFamilyAccessToBaby(babyId) ||
          hasGuestAccessToBaby(babyId)
        );

        // Create/Update/Delete: only parent of the baby
        allow create, update, delete: if isAuthenticated() && isParentOfBaby(babyId);
      }
    }

    // ===================
    // EVENTS COLLECTION
    // ===================
    match /events/{eventId} {
      // Read: parent OR family member OR guest with access
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.parentId == request.auth.uid ||
        isParentOfBaby(resource.data.childId) ||
        hasFamilyAccessToBaby(resource.data.childId) ||
        hasGuestAccessToBaby(resource.data.childId)
      );
      
      // Create: must be the creator (userId/parentId) AND actually have access to the
      // child — blocks injecting events into a stranger's timeline with a harvested childId
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.parentId == request.auth.uid
      ) && (
        isParentOfBaby(request.resource.data.childId) ||
        hasFamilyAccessToBaby(request.resource.data.childId) ||
        hasGuestAccessToBaby(request.resource.data.childId)
      );
      
      // Update/Delete: creator, parent field, or actual parent of the baby (for account deletion)
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid ||
        resource.data.parentId == request.auth.uid ||
        isParentOfBaby(resource.data.childId)
      );
    }

    // ===================
    // INVITES COLLECTION
    // ===================
    match /invites/{inviteCode} {
      // Read: creator only. Joins resolve the code SERVER-SIDE via the
      // joinFamilyByCode Cloud Function (throttled 10 attempts/hour), so the
      // client never needs to read foreign invites — this closes both bulk
      // enumeration and direct brute-force of the 6-digit code space.
      allow get: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow list: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      // Create: creator must stamp themselves (no forging invites for others)
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      // Update/Delete: creator only ('used' marking is done by the Cloud Function)
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // ===================
    // PRESENCE COLLECTION
    // ===================
    match /presence/{docId} {
      allow read: if isAuthenticated() && request.auth.uid == docId;
      allow write: if isAuthenticated() && request.auth.uid == docId;
    }

    // =================== 
    // SITTERS COLLECTION
    // ===================
    match /sitters/{sitterId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && request.query.limit <= 100;
      allow create: if isAuthenticated() && request.auth.uid == sitterId;
      allow update, delete: if isAuthenticated() && request.auth.uid == sitterId;
    }

    // ===================
    // CHATS COLLECTION
    // ===================
    match /chats/{chatId} {
      // Read: participants only
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Create: if user is in participants
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      // Update: participants only (for unread counts, last message)
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        // Read: if user is chat participant
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Create: if user is chat participant and is the sender
        allow create: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                         request.resource.data.senderId == request.auth.uid;

        // Delete: sender can delete their own messages
        allow delete: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                         resource.data.senderId == request.auth.uid;
      }
    }

    // ===================
    // BOOKINGS COLLECTION
    // ===================
    match /bookings/{bookingId} {
      // Read: only parent or babysitter involved in the booking
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.babysitterId == request.auth.uid
      );
      
      allow create: if isAuthenticated() && request.resource.data.parentId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.babysitterId == request.auth.uid
      );
      allow delete: if isAuthenticated() && resource.data.parentId == request.auth.uid;
    }

    // ===================
    // ACTIVE SHIFTS COLLECTION
    // ===================
    match /activeShifts/{shiftId} {
      // Read: parent or babysitter involved in the shift
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.babysitterId == request.auth.uid
      );
      
      // Create: babysitter can start a shift
      allow create: if isAuthenticated() && 
        request.resource.data.babysitterId == request.auth.uid;
      
      // Update: babysitter or parent can update (pause, etc)
      allow update: if isAuthenticated() && (
        resource.data.babysitterId == request.auth.uid ||
        resource.data.parentId == request.auth.uid
      );
      
      // Delete: babysitter or parent can end shift
      allow delete: if isAuthenticated() && (
        resource.data.babysitterId == request.auth.uid ||
        resource.data.parentId == request.auth.uid
      );
    }

    // ===================
    // REVIEWS COLLECTION
    // ===================
    match /reviews/{reviewId} {
      // Read: any authenticated user (reviews are public for all sitters)
      allow read: if isAuthenticated();
      
      // Create: any authenticated user (parent can create review)
      allow create: if isAuthenticated() && request.resource.data.parentId == request.auth.uid;
      
      // Update: 
      // - Parent can update their own review
      // - Sitter can add response to their review (only sitterResponse field)
      // - Anyone can update helpfulCount/helpfulBy (for marking as helpful)
      allow update: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        (resource.data.babysitterId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sitterResponse'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpfulCount', 'helpfulBy'])
      );
      
      // Delete: only parent who created the review
      allow delete: if isAuthenticated() && resource.data.parentId == request.auth.uid;
    }

    // ===================
    // NOTIFICATIONS COLLECTION
    // ===================
    match /notifications/{notificationId} {
      // Strict read access (OWNER ONLY)
      allow read: if isOwner(resource.data.userId);
      
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ===================
    // DAILY LOGS COLLECTION
    // ===================
    match /dailyLogs/{logId} {
      // Read: creator OR family access
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        (resource.data.get('childId', null) != null && (isParentOfBaby(resource.data.childId) || hasFamilyAccessToBaby(resource.data.childId) || hasGuestAccessToBaby(resource.data.childId)))
      );
      
      // Create: must own the log (parentId must match caller)
      allow create: if isAuthenticated() && request.resource.data.parentId == request.auth.uid;

      // Update/Delete: creator only
      allow update, delete: if isAuthenticated() && resource.data.parentId == request.auth.uid;
    }

    // ===================
    // GROWTH MEASUREMENTS COLLECTION
    // ===================
    match /growthMeasurements/{measurementId} {
      // Read: access via family logic or direct parent
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        (resource.data.get('babyId', null) != null && (isParentOfBaby(resource.data.babyId) || hasFamilyAccessToBaby(resource.data.babyId) || hasGuestAccessToBaby(resource.data.babyId)))
      );
      
      // Create: must own the measurement (createdBy must match caller)
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;

      // Update/Delete: creator only
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // ===================
    // PROFILE VIEWS COLLECTION
    // ===================
    match /profileViews/{viewId} {
      // Read: only the sitter whose profile was viewed, or the viewer themselves
      allow read: if isAuthenticated() && (
        resource.data.sitterId == request.auth.uid ||
        resource.data.viewerId == request.auth.uid
      );

      // Create: any authenticated user can record a view
      allow create: if isAuthenticated() && request.resource.data.viewerId == request.auth.uid;
    }

    // ===================
    // CONTACT MESSAGES COLLECTION
    // ===================
    match /contactMessages/{msgId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // ===================
    // SITTER REPORTS COLLECTION
    // ===================
    match /sitter_reports/{reportId} {
      // Create: any authenticated user can report a sitter (must be their own ID)
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      // Read/Update/Delete: admin only via console
      allow read, update, delete: if false;
    }

    // ===================
    // MAIL COLLECTION (Firebase "Trigger Email" Extension)
    // ===================
    match /mail/{msgId} {
      // Only allow creating mail tied to the current user's UID to prevent spam abuse
      allow create: if isAuthenticated() && request.resource.data.get('uid', '') == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ===================
    // SYSTEM COLLECTION
    // ===================
    match /system/{docId} {
      allow read: if true; // Allow all users (even unauthenticated) to read system settings like premium override
      allow write: if false; // Only admin via console can modify
    }

    // ===================
    // APP SETTINGS COLLECTION (Remote Config Alternative)
    // ===================
    match /app_settings/{docId} {
      allow read: if true; // Must be public so app can fetch config before login
      allow write: if false; // Only admin via console can modify
    }

    // ===================
    // TEETH TRACKER COLLECTION
    // ===================
    match /teeth/{toothId} {
      // Read: creator OR parent/family member of the child
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        (resource.data.get('childId', null) != null && (
          isParentOfBaby(resource.data.childId) ||
          hasFamilyAccessToBaby(resource.data.childId) ||
          hasGuestAccessToBaby(resource.data.childId)
        ))
      );

      // Create: must own the record (createdBy must match caller)
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;

      // Update/Delete: creator only
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
  }
}
