rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function for file validation
    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024 // 10MB
          && request.resource.contentType.matches('image/.*');
    }
    
    // Sitter Photos
    match /sitterPhotos/{userId}/{filename} {
      // Allow authenticated users to upload their own photos
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidImage();
    }
    
    // Child Photos — read restricted to owner only (family members access via signed download URLs)
    match /childPhotos/{userId}/{childId}/{filename} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidImage();
    }

    // User Photos — owner only
    match /userPhotos/{userId}/{filename} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidImage();
    }

    // Baby Photos (legacy path compatibility) — owner only
    match /babyPhotos/{userId}/{babyId}/{filename} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidImage();
    }
    
    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
