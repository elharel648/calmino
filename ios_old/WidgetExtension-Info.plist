<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 
    ==================================
    הגדרות Info.plist עבור Live Activity
    ==================================
    
    קובץ זה מכיל את ההגדרות הנדרשות עבור Widget Extension
    שמכיל Live Activities
    -->
    
    <!-- שם התצוגה של ה-Widget -->
    <key>CFBundleDisplayName</key>
    <string>CalmParent Activities</string>
    
    <!-- Bundle Identifier -->
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    <!-- גרסה -->
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    
    <!-- 
    ========================================
    הגדרות Live Activity - חובה!
    ========================================
    -->
    
    <!-- מאפשר Live Activities -->
    <key>NSSupportsLiveActivities</key>
    <true/>
    
    <!-- מאפשר עדכונים תכופים (לטיימר בזמן אמת) -->
    <key>NSSupportsLiveActivitiesFrequentUpdates</key>
    <true/>
    
    <!-- 
    ========================================
    הגדרות Widget Extension
    ========================================
    -->
    
    <!-- הרחבת Widget -->
    <key>NSExtension</key>
    <dict>
        <!-- סוג ההרחבה -->
        <key>NSExtensionPointIdentifier</key>
        <string>com.apple.widgetkit-extension</string>
    </dict>
    
    <!-- 
    ========================================
    הגדרות Push Notifications (אופציונלי)
    ========================================
    
    אם רוצים לעדכן את ה-Live Activity מהשרת
    -->
    
    <!-- מצב Push Notifications -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>
    
    <!-- 
    ========================================
    הגדרות נוספות
    ========================================
    -->
    
    <!-- מונע פתיחה ישירה של ההרחבה -->
    <key>NSExtensionPrincipalClass</key>
    <string></string>
    
    <!-- הגדרות נגישות -->
    <key>UIAccessibilityTraits</key>
    <string>Updates Frequently</string>
    
    <!-- תמיכה במכשירים -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer> <!-- iPhone -->
        <integer>2</integer> <!-- iPad -->
    </array>
    
    <!-- גרסת iOS מינימלית -->
    <key>MinimumOSVersion</key>
    <string>16.2</string>
    
    <!-- 
    ========================================
    הערות חשובות:
    ========================================
    
    1. NSSupportsLiveActivities חייב להיות true
    2. NSSupportsLiveActivitiesFrequentUpdates מאפשר עדכונים כל שנייה
    3. ה-Widget Extension חייב להיות target נפרד
    4. Bundle Identifier חייב להיות: com.yourapp.bundleid.WidgetExtension
    5. הקובץ הזה הולך ל-Widget Extension Target, לא ל-Main App
    
    ========================================
    -->
</dict>
</plist>
