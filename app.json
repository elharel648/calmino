{
  "expo": {
    "name": "Calmino",
    "slug": "CalmParentApp",
    "scheme": "calmparentapp",
    "version": "1.1.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "@react-native-firebase/crashlytics",
      [
        "expo-image-picker",
        {
          "photosPermission": "האפליקציה צריכה גישה לתמונות כדי להגדיר תמונת פרופיל"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "האפליקציה צריכה גישה למצלמה כדי לסרוק ברקוד ולהצטרף למשפחה"
        }
      ],
      "expo-local-authentication",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "16.1"
          }
        }
      ],
      "./plugins/withFirebaseWarningFix",
      "./plugins/withLiveActivity",
      "@react-native-google-signin/google-signin",
      "@react-native-firebase/perf"
    ],
    "splash": {
      "image": "./assets/splash-clean.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F6F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harel.calmparentapp",
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.calmparent.shared"
        ]
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleIconName": "AppIcon",
        "NSPhotoLibraryUsageDescription": "האפליקציה צריכה גישה לתמונות כדי להגדיר תמונת פרופיל",
        "NSCameraUsageDescription": "האפליקציה צריכה גישה למצלמה כדי לסרוק ברקוד ולהצטרף למשפחה",
        "NSFaceIDUsageDescription": "אפשר כניסה מהירה ומאובטחת באמצעות Face ID",
        "NSLocationWhenInUseUsageDescription": "האפליקציה צריכה גישה למיקום כדי למצוא בייביסיטרים באזור שלך",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "האפליקציה צריכה גישה למיקום כדי למצוא בייביסיטרים באזור שלך",
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true,
        "UIBackgroundModes": [
          "audio"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.16421819020-muvdskd7ppjnfcrnal4lsra01pqjr505",
              "calmparentapp"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.harel.calmparentapp",
      "versionCode": 6,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0af00389-5a5c-48ad-aa91-1b083f8e494e",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "CalmParentLiveActivity",
                  "bundleIdentifier": "com.harel.calmparentapp.LiveActivity",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.calmparent.shared"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/0af00389-5a5c-48ad-aa91-1b083f8e494e"
    },
    "runtimeVersion": "1.1.4"
  }
}