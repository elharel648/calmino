# EAS Build ignore file
# Excludes local build artifacts and native directories
# EAS Cloud runs `npx expo prebuild` to generate fresh native projects

node_modules/
.expo/
.DS_Store
*.log
dist/

# Native directories — generated fresh by EAS prebuild
# Do NOT include local android/ or ios/ builds (causes variant mismatches)
android/.gradle/
android/app/build/
ios/Pods/
ios/build/
ios/DerivedData/

# IDE & tooling
.claude/
.gemini/
.idea/
.vscode/

# Keep .env.local out (contains sensitive Sentry token)
.env.local
ios_backup/
android_backup/
