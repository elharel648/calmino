# EAS Build ignore file
# Excludes local build artifacts to keep upload small

node_modules/
.expo/
.DS_Store
*.log
dist/

# Local build artifacts (regenerated in EAS Cloud)
android/app/build/
android/.gradle/
ios/build/
ios/Pods/

# IDE & tooling
.claude/
.gemini/
.idea/
.vscode/

# Keep .env.local out (contains sensitive Sentry token)
.env.local
